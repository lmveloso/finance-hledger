# Caminho absoluto pro seu arquivo hledger
LEDGER_FILE=/home/seu-usuario/finances/2026.journal

# Caminho do binário hledger (geralmente apenas "hledger")
HLEDGER_PATH=hledger

# CORS — em produção restrinja pra sua URL Tailscale específica
CORS_ORIGINS=*

# ── Authentication ─────────────────────────────────────────────────────────
# Modes: none | password | tailscale | tailscale+password
# Production behind `tailscale serve` should use "tailscale+password" (default
# of production recipes) so password remains a fallback off-tailnet.
AUTH_MODE=none

# Bearer-token passwords (used when auth_mode includes "password")
# PASSWORD_LUCAS=change-me
# PASSWORD_GIO=change-me

# Shared secret sent by the Tailscale reverse proxy as
# X-Tailscale-Proxy-Secret. When set, incoming Tailscale-User-* headers are
# only trusted if this secret matches.
# TAILSCALE_PROXY_SECRET=

# ── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# "json" (default) for production ingestion; "console" for local dev.
LOG_FORMAT=json
