    "expenses:despesas-pessoais:mesada":                        "custos-fixos",
    "expenses:despesas-pessoais:cuidados-pessoais":             "conforto",
    "expenses:despesas-pessoais:roupas":                        "conforto",
    "expenses:despesas-pessoais:presentes":                     "prazeres",
